{
  "fieldSchema": {
    "type": "object",
    "title": "Order Event Payload",
    "required": [
      "member_id",
      "eventType"
    ],
    "properties": {
      "order_id": {
        "type": "string",
        "title": "Order ID"
      },
      "member_id": {
        "type": "string",
        "title": "Member ID"
      },
      "order_amount": {
        "type": "number",
        "title": "Order Amount"
      },
      "total_amount": {
        "type": "number",
        "title": "Total Amount"
      },
      "item_count": {
        "type": "number",
        "title": "Item Count"
      },
      "item_category": {
        "type": "string",
        "title": "Item Category"
      },
      "channel": {
        "type": "string",
        "title": "Channel",
        "enum": [
          "TMALL",
          "JD",
          "DOUYIN",
          "WECHAT_MINI"
        ]
      },
      "trade_status": {
        "type": "string",
        "title": "Trade Status",
        "enum": [
          "WAIT_BUYER_PAY",
          "WAIT_SELLER_SEND_GOODS",
          "WAIT_BUYER_CONFIRM_GOODS",
          "TRADE_FINISHED",
          "TRADE_CLOSED"
        ]
      },
      "trade_time": {
        "type": "string",
        "title": "Trade Time",
        "format": "date-time"
      },
      "pay_time": {
        "type": "string",
        "title": "Pay Time",
        "format": "date-time"
      },
      "buyer_nick": {
        "type": "string",
        "title": "Buyer Nick"
      },
      "eventType": {
        "type": "string",
        "title": "Event Type",
        "enum": [
          "ORDER_PAID"
        ]
      },
      "remark": {
        "type": "string",
        "title": "Remark"
      },
      "refundId": {
        "type": "string",
        "title": "退单编号"
      },
      "orderitems": {
        "type": "array",
        "title": "ORDERITEM 列表",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "title": "ID"
            },
            "sku": {
              "type": "string",
              "title": "SKU"
            },
            "price": {
              "type": "number",
              "title": "单价"
            },
            "quantity": {
              "type": "number",
              "title": "数量"
            },
            "productName": {
              "type": "string",
              "title": "商品名称"
            }
          }
        }
      }
    }
  }
}